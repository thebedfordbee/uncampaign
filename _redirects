# Cloudflare Pages redirect rules
# Clean URL routing — redirects short canonical paths to actual file-based routes.
# Cloudflare Pages automatically strips .html extensions, so /pages/photos.html
# is served at /pages/photos. These 301s make the shorter canonical URLs real routes.

/photos             /pages/photos           301
/podcasts           /pages/podcasts         301
/best-of-bedford                  /pages/best-of-bedford                  301
/best-of-bedford-fastest-typist   /pages/best-of-bedford-fastest-typist   301
/best-of-bedford-cutest-pet       /pages/best-of-bedford-cutest-pet       301

# Legacy /minutes and /minute redirects — keep old links working
/minutes        /podcasts           301
/minute         /podcasts           301
/pages/minutes  /podcasts           301
